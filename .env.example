# Database configuration
DATABASE_URL=postgresql://typeahead_user:typeahead_pass@localhost:5432/typeahead_db

# Redis connection endpoints (comma-separated list of host:port)
# For docker, these are container hostnames: redis-1:6379,redis-2:6379,redis-3:6379
# For local fallback, they could be localhost:6379,localhost:6380,localhost:6381
REDIS_NODES=redis-1:6379,redis-2:6379,redis-3:6379

# FastAPI configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# Batch Ingestion configurations
BATCH_SIZE_LIMIT=100
BATCH_FLUSH_INTERVAL=3.0

# Trending scoring configurations
TRENDING_INTERVAL_SECONDS=30.0
TRENDING_ALPHA=0.2
TRENDING_BETA=0.8
RECENCY_WINDOW_HOURS=2.0

